<h2>Login</h2>

<% if (errors && errors.length > 0) { %>
  <ul>
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/account/login" method="post">
  <label for="email">Email</label>
  <input 
    type="email" 
    id="email" 
    name="email" 
    value="<%= oldData.email || '' %>" 
    required
  >

  <label for="password">Password</label>
  <input 
    type="password" 
    id="password" 
    name="password" 
    required
  >

  <button type="submit">Login</button>
</form>