<h2>Manage Service Requests</h2>
<% if (!requests.length) { %><p>There are no service requests.</p><% } else { %>
<div class="table-wrap"><table><thead><tr><th>Customer</th><th>Vehicle</th><th>Service</th><th>Preferred date</th><th>Status</th></tr></thead><tbody>
<% requests.forEach(request => { %><tr>
  <td><%= request.first_name %> <%= request.last_name %><br><small><%= request.email %></small></td>
  <td><%= [request.display_year, request.display_make, request.display_model].filter(Boolean).join(" ") || "Not specified" %></td>
  <td><strong><%= request.service_type %></strong><br><%= request.description %></td>
  <td><%= request.preferred_date ? new Date(request.preferred_date).toLocaleDateString() : "No preference" %></td>
  <td><form method="post" action="/admin/service-requests/<%= request.service_request_id %>/status" class="inline-form">
    <select name="status"><% statuses.forEach(status => { %><option value="<%= status %>" <%= request.status === status ? "selected" : "" %>><%= status.replace("_", " ") %></option><% }) %></select>
    <button type="submit">Update</button></form></td>
</tr><% }) %></tbody></table></div><% } %>
